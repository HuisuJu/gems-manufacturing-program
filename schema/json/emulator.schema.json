{
  "title": "GEMS Emulator Factory Data",
  "model": "emulator",
  "required": [
    "manufactured_date",
    "dac_cert",
    "dac_public_key",
    "dac_private_key",
    "pai_cert",
    "cd_cert",
    "spake2p_passcode",
    "spake2p_salt",
    "spake2p_iteration_count",
    "spake2p_verifier_w0",
    "spake2p_verifier_L",
    "discriminator",
    "onboarding_payload"
  ],
  "properties": {
    "vendor_id": {
      "const": 65521,
      "description": "Matter Vendor ID (0xFFF1)"
    },

    "product_id": {
      "const": 32768,
      "description": "Matter Product ID for Emulator (0x8000)"
    },

    "custom_flow": {
      "const": 0,
      "description": "Matter commissioning flow. Standard flow is 0."
    },

    "discovery_capabilities": {
      "const": 2,
      "description": "Matter discovery capability bitmask used for onboarding payload generation. BLE only is 2."
    },

    "spake2p_iteration_count": {
      "const": 1000,
      "description": "Matter SPAKE2+ iteration count"
    },

    "spake2p_salt": {
      "minLength": 32,
      "maxLength": 32,
      "description": "SPAKE2+ salt hex length for Emulator model (16 bytes)"
    }
  }
}