{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "GEMS Factory Data Base Schema",
  "type": "object",
  "properties": {
    "serial_number": {
      "type": "string",
      "maxLength": 64,
      "description": "Unique device serial number"
    },

    "manufactured_date": {
      "type": "string",
      "description": "Manufacturing date in YYYYMMDD format",
      "maxLength": 8,
      "pattern": "^\\d{8}$"
    },

    "vendor_id": {
      "type": "integer",
      "minimum": 0,
      "maximum": 4294967295,
      "description": "Matter Vendor ID"
    },

    "product_id": {
      "type": "integer",
      "minimum": 0,
      "maximum": 4294967295,
      "description": "Matter Product ID"
    },

    "custom_flow": {
      "type": "integer",
      "description": "Matter commissioning flow"
    },

    "discovery_capabilities": {
      "type": "integer",
      "description": "Matter discovery capability bitmask used for onboarding payload generation"
    },

    "dac_cert": {
      "type": "string",
      "pattern": "^[0-9A-Fa-f]+$",
      "maxLength": 1400,
      "description": "Device Attestation Certificate as hex string (bytes, max 700)"
    },

    "dac_public_key": {
      "type": "string",
      "pattern": "^[0-9A-Fa-f]+$",
      "minLength": 130,
      "maxLength": 130,
      "description": "Device Attestation Public Key as hex string (bytes, 65)"
    },

    "dac_private_key": {
      "type": "string",
      "pattern": "^[0-9A-Fa-f]+$",
      "minLength": 64,
      "maxLength": 64,
      "description": "Device Attestation Private Key as hex string (bytes, 32)"
    },

    "pai_cert": {
      "type": "string",
      "pattern": "^[0-9A-Fa-f]+$",
      "maxLength": 1400,
      "description": "Product Attestation Intermediate Certificate as hex string (bytes, max 700)"
    },

    "cd_cert": {
      "type": "string",
      "pattern": "^[0-9A-Fa-f]+$",
      "maxLength": 1024,
      "description": "Matter Certification Declaration as hex string (bytes, max 512)"
    },

    "spake2p_passcode": {
      "type": "integer",
      "minimum": 0,
      "maximum": 4294967295,
      "description": "Matter SPAKE2+ passcode"
    },

    "spake2p_salt": {
      "type": "string",
      "pattern": "^[0-9A-Fa-f]+$",
      "anyOf": [
        {
          "minLength": 32,
          "maxLength": 32
        },
        {
          "minLength": 64,
          "maxLength": 64
        }
      ],
      "description": "SPAKE2+ salt as hex string (16 or 32 bytes)"
    },

    "spake2p_iteration_count": {
      "type": "integer",
      "minimum": 0,
      "maximum": 4294967295,
      "description": "Matter SPAKE2+ iteration count"
    },

    "spake2p_verifier_w0": {
      "type": "string",
      "pattern": "^[0-9A-Fa-f]+$",
      "minLength": 64,
      "maxLength": 64,
      "description": "SPAKE2+ verifier W0 as hex string (bytes, 32)"
    },

    "spake2p_verifier_L": {
      "type": "string",
      "pattern": "^[0-9A-Fa-f]+$",
      "minLength": 130,
      "maxLength": 130,
      "description": "SPAKE2+ verifier L as hex string (bytes, 65)"
    },

    "discriminator": {
      "type": "integer",
      "minimum": 0,
      "maximum": 4095,
      "description": "Matter discriminator"
    },

    "onboarding_payload": {
      "type": "string",
      "maxLength": 100,
      "description": "Matter onboarding payload string"
    }
  },
  "additionalProperties": false
}