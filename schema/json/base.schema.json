{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Base Matter Factory Data",
  "type": "object",
  "properties": {
    "serial_number": {
      "type": "string",
      "description": "Unique device serial number"
    },

    "manufactured_date": {
      "type": "string",
      "description": "Manufacturing date in YYYYMMDD format",
      "pattern": "^\\d{8}$"
    },

    "vendor_id": {
      "type": "integer",
      "description": "Matter Vendor ID"
    },

    "product_id": {
      "type": "integer",
      "description": "Matter Product ID"
    },

    "custom_flow": {
      "type": "integer",
      "description": "Matter commissioning flow"
    },

    "discovery_capabilities": {
      "type": "integer",
      "description": "Matter discovery capability bitmask used for onboarding payload generation"
    },

    "dac_cert": {
      "type": "string",
      "description": "Device Attestation Certificate"
    },

    "dac_public_key": {
      "type": "string",
      "description": "Device Attestation Public Key"
    },

    "dac_private_key": {
      "type": "string",
      "description": "Device Attestation Private Key"
    },

    "pai_cert": {
      "type": "string",
      "description": "Product Attestation Intermediate Certificate"
    },

    "certification_declaration": {
      "type": "string",
      "description": "Matter Certification Declaration"
    },

    "spake2p_passcode": {
      "type": "integer",
      "minimum": 0,
      "maximum": 99999999,
      "description": "Matter SPAKE2+ passcode"
    },

    "spake2p_salt": {
      "type": "string",
      "description": "SPAKE2+ salt encoded as Base64"
    },

    "spake2p_iteration_count": {
      "type": "integer",
      "description": "Matter SPAKE2+ iteration count"
    },

    "spake2p_verifier": {
      "type": "string",
      "description": "SPAKE2+ verifier encoded as Base64"
    },

    "onboarding_payload": {
      "type": "string",
      "description": "Matter onboarding QR payload string beginning with MT:"
    }
  },
  "additionalProperties": false
}