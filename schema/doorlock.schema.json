{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Doorlock Factory Data",
  "type": "object",

  "required": [
    "serial_number",
    "manufactured_date",

    "vendor_id",
    "product_id",
    "custom_flow",
    "discovery_capabilities",

    "dac_cert",
    "dac_private_key",
    "pai_cert",
    "certification_declaration",

    "spake2p_passcode",
    "spake2p_salt",
    "spake2p_iteration_count",
    "spake2p_verifier",

    "onboarding_payload"
  ],

  "properties": {
    "serial_number": {
      "type": "string",
      "description": "Unique device serial number"
    },

    "manufactured_date": {
      "type": "string",
      "description": "Manufacturing date (YYYY-MM-DD)",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },

    "vendor_id": {
      "type": "integer",
      "const": 4142,
      "description": "Matter Vendor ID (0x102E)"
    },

    "product_id": {
      "type": "integer",
      "const": 8896,
      "description": "Matter Product ID for Doorlock (0x22C0)"
    },

    "custom_flow": {
      "type": "integer",
      "const": 0,
      "description": "Matter commissioning flow. Standard flow is 0."
    },

    "discovery_capabilities": {
      "type": "integer",
      "const": 2,
      "description": "Matter discovery capability bitmask used for onboarding payload generation. BLE only is 2."
    },

    "dac_cert": {
      "type": "string",
      "description": "Device Attestation Certificate"
    },

    "dac_private_key": {
      "type": "string",
      "description": "Device Attestation Private Key"
    },

    "pai_cert": {
      "type": "string",
      "description": "Product Attestation Intermediate Certificate"
    },

    "certification_declaration": {
      "type": "string",
      "description": "Matter Certification Declaration"
    },

    "spake2p_passcode": {
      "type": "integer",
      "minimum": 0,
      "maximum": 99999999,
      "description": "Matter SPAKE2+ passcode"
    },

    "spake2p_salt": {
      "type": "string",
      "description": "SPAKE2+ salt encoded as Base64"
    },

    "spake2p_iteration_count": {
      "type": "integer",
      "const": 1000,
      "description": "Matter SPAKE2+ iteration count"
    },

    "spake2p_verifier": {
      "type": "string",
      "description": "SPAKE2+ verifier encoded as Base64"
    },

    "onboarding_payload": {
      "type": "string",
      "description": "Matter onboarding QR payload string beginning with MT:"
    }
  },

  "additionalProperties": false
}