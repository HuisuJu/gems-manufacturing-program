{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Doorlock Factory Data",
  "type": "object",

  "required": [
    "serial_number",
    "manufactured_date",

    "dac_cert",
    "dac_private_key",
    "pai_cert",
    "certification_declaration",

    "spake2p_passcode",
    "spake2p_salt",
    "spake2p_iteration_count",
    "spake2p_verifier",

    "onboarding_payload"
  ],

  "properties": {

    "serial_number": {
      "type": "string",
      "description": "Unique device serial number"
    },

    "manufactured_date": {
      "type": "string",
      "description": "Manufacturing date (YYYY-MM-DD)",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },

    "dac_cert": {
      "type": "string",
      "description": "Device Attestation Certificate"
    },

    "dac_private_key": {
      "type": "string",
      "description": "Device Attestation Private Key"
    },

    "pai_cert": {
      "type": "string",
      "description": "Product Attestation Intermediate Certificate"
    },

    "certification_declaration": {
      "type": "string",
      "description": "Matter Certification Declaration"
    },

    "spake2p_passcode": {
      "type": "integer",
      "minimum": 0,
      "maximum": 99999999,
      "description": "Matter SPAKE2+ passcode"
    },

    "spake2p_salt": {
      "type": "string",
      "description": "SPAKE2+ salt"
    },

    "spake2p_iteration_count": {
      "type": "integer",
      "minimum": 1,
      "description": "SPAKE2+ iteration count"
    },

    "spake2p_verifier": {
      "type": "string",
      "description": "SPAKE2+ verifier"
    },

    "onboarding_payload": {
      "type": "string",
      "description": "Matter onboarding payload"
    }

  },

  "additionalProperties": false
}